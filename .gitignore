sangph2612.inp
sangph2612.out

# IDE and editor files
.vscode/
.idea/
*.suo
*.user
*.userosscache
*.sln.docstates

# OS files
.DS_Store
Thumbs.db

# Logs
*.log

# Generated documentation exports
docstring.txt

